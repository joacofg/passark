# PassArk local development environment
# Copy this file to .env and replace placeholder values for local use only.
# Do not commit real secrets.

PASSARK_ENV=development

# PostgreSQL
POSTGRES_DB=passark
POSTGRES_USER=passark
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://passark:change-me@postgres:5432/passark
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@passark.local
AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
AUTH_SESSION_COOKIE_NAME=passark_session
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_COOKIE_SAMESITE=lax
AUTH_SESSION_COOKIE_DOMAIN=
AUTH_SESSION_TTL_HOURS=24

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
